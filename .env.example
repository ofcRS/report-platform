# Copy to .env and fill in. Never commit .env.

# Required. 64+ chars, used to sign/encrypt cookies and session tokens.
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname the app advertises (URL generation + origin check).
# Keep "localhost" for purely-local docker compose; set to your domain in prod.
PHX_HOST=localhost

# Optional overrides (sensible defaults exist):
# DATABASE_URL=ecto://postgres:postgres@postgres:5432/report_platform
# PORT=4000
# POOL_SIZE=10
# ARTIFACT_ROOT=/app/artifacts
