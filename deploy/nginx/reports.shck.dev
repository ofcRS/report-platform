# nginx site for reports.shck.dev — proxies to the Docker app container on
# 127.0.0.1:4001. Drop this under /etc/nginx/sites-available/ and symlink into
# sites-enabled/, then `sudo certbot --nginx -d reports.shck.dev` to add TLS.
#
# This block is intentionally the HTTP-only version; certbot's nginx plugin
# will rewrite it in place to add `listen 443 ssl`, the cert paths, and an
# HTTP→HTTPS redirect.

server {
    server_name reports.shck.dev;
    listen 80;
    listen [::]:80;

    # Generous body size for the occasional artifact upload / download.
    client_max_body_size 32m;

    location / {
        proxy_pass http://127.0.0.1:4001;
        proxy_http_version 1.1;

        # WebSocket upgrade for Phoenix LiveView.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Give PDF rendering a generous read timeout (headless Chrome + 30d chart).
        proxy_read_timeout 60s;
    }
}
